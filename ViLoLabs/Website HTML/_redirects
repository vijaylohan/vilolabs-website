# ViLoLabs — Cloudflare Pages _redirects
# ──────────────────────────────────────────────────────────────
# Cloudflare Pages auto-strips `.html` extensions and auto-serves
# directory index.html files. Targets here are written WITHOUT .html
# (and with a trailing slash for directory roots) so Cloudflare's
# normalization layer doesn't reject the rewrite.
#
# Status 200 = rewrite (URL stays the same in browser, target page served).
# Client-side JS on the target reads location.pathname and renders the
# slug-specific view.

# Pretty URLs for /worksheets/<slug>  →  serve /worksheets/index.html
/worksheets/*    /worksheets/    200

# Tool-share pretty URLs — /tools/<tool>/<slug>  →  serve /tools/<tool>.html
# (Cloudflare resolves the extensionless path to the underlying .html file.)
/tools/resize-image/*      /tools/resize-image      200
/tools/qr-generator/*      /tools/qr-generator      200
/tools/image-to-pdf/*      /tools/image-to-pdf      200
/tools/compress-image/*    /tools/compress-image    200
/tools/compress-pdf/*      /tools/compress-pdf      200
/tools/merge-pdf/*         /tools/merge-pdf         200

# (Add more redirects here as the site grows.)

# Dependencies + caches
node_modules/
ViLoLabs/node_modules/
ViLoLabs/.npm-cache/
.npm-cache/

# Asset backups (auto-generated by build-all.js, large + redundant)
ViLoLabs/.asset-backups/

# Reference-only folders (large, not part of deployable)
Resources/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor junk
.vscode/
.idea/
*.swp
*.swo

# Build / logs
*.log
npm-debug.log*

# Wrangler local dev cache (Cloudflare Pages Functions emulator)
.wrangler/
ViLoLabs/.wrangler/
ViLoLabs/Website HTML/.wrangler/

# Local environment overrides (never commit secrets)
.env
.env.local
.env.*.local

# Claude Code session files
.claude/projects/
.claude/sessions/

# Local backups (manual logo/asset reverts — keep local only)
.logo-revert/

# Per-machine Claude Code settings (personal permissions list, not project config)
.claude/settings.local.json
